# arcnext shell integration — restore ZDOTDIR first, then inject OSC 7

# Restore original ZDOTDIR immediately so .zprofile, .zshrc, .zlogin load normally
ZDOTDIR="$ARCNEXT_ORIGINAL_ZDOTDIR"

# Source the user's real .zshenv
if [[ -f "$ARCNEXT_ORIGINAL_ZDOTDIR/.zshenv" ]]; then
  source "$ARCNEXT_ORIGINAL_ZDOTDIR/.zshenv"
elif [[ -f "$HOME/.zshenv" ]]; then
  source "$HOME/.zshenv"
fi

# Inject shell integration hooks
if [[ -n "$ARCNEXT_SHELL_INTEGRATION" ]]; then
  autoload -Uz add-zsh-hook

  # OSC 7 — directory tracking
  __arcnext_osc7() {
    printf '\e]7;file://%s%s\a' "${HOST}" "${PWD}"
  }
  add-zsh-hook chpwd __arcnext_osc7
  __arcnext_osc7

  # OSC 7771 — command lifecycle tracking (for AI agent detection)
  # preexec: fires when user hits Enter, before the command runs
  __arcnext_preexec() {
    local cmd="${1%% *}"
    printf '\e]7771;cmd:%s\a' "${cmd}"
  }
  # precmd: fires when the command finishes and the prompt is about to display
  __arcnext_precmd() {
    printf '\e]7771;prompt\a'
  }
  add-zsh-hook preexec __arcnext_preexec
  add-zsh-hook precmd __arcnext_precmd
fi
