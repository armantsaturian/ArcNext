{
  "name": "arcnext",
  "version": "0.3.1",
  "description": "Terminal emulator with Arc browser-style UX, built for developers who live in the terminal with AI agents.",
  "main": "./out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.arcnext.app",
    "productName": "ArcNext",
    "icon": "arcnext.png",
    "afterPack": "./scripts/after-pack.cjs",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "Arxtage",
      "repo": "arcnext"
    },
    "files": [
      "out/**/*"
    ],
    "asarUnpack": [
      "out/main/shell-integration/**"
    ]
  }
}
